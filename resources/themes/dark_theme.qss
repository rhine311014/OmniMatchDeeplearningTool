/* 20260322 ZJH 暗色主题样式表 - 参考 MVTec Deep Learning Tool 配色方案 */
/* 配色说明：
   主背景:     #1a1d23  深灰蓝，主窗口底色
   次要背景:   #22262e  稍浅，面板/输入框背景
   边框色:     #2e3340  分隔线和边框
   强调蓝:     #2563eb  主操作按钮、选中高亮
   强调蓝悬停: #3b82f6  按钮悬停态
   主文字:     #e2e8f0  高亮白
   次要文字:   #94a3b8  辅助说明文字
   成功绿:     #22c55e
   警告橙:     #f59e0b
   错误红:     #ef4444
*/

/* ─── QMainWindow / QWidget 基础背景 ─── */
QMainWindow {
    background-color: #1a1d23;
    color: #e2e8f0;
}

QWidget {
    background-color: #1a1d23;
    color: #e2e8f0;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
    font-size: 13px;
}

/* ─── QPushButton 四态：正常/悬停/按下/禁用 ─── */
QPushButton {
    background-color: #2563eb;
    color: #ffffff;
    border: none;
    border-radius: 4px;
    padding: 6px 16px;
    min-height: 28px;
    font-size: 13px;
    font-weight: 500;
}

QPushButton:hover {
    background-color: #3b82f6;
}

QPushButton:pressed {
    background-color: #1d4ed8;
}

QPushButton:disabled {
    background-color: #2e3340;
    color: #4b5563;
}

/* 20260322 ZJH 次要（扁平）按钮风格：用于工具栏等非主操作场景 */
QPushButton[flat="true"] {
    background-color: #22262e;
    color: #e2e8f0;
    border: 1px solid #2e3340;
}

QPushButton[flat="true"]:hover {
    background-color: #2e3340;
    border-color: #3b82f6;
}

/* ─── QToolButton 工具栏按钮 ─── */
QToolButton {
    background-color: transparent;
    color: #e2e8f0;
    border: none;
    border-radius: 4px;
    padding: 4px 8px;
    min-width: 28px;
    min-height: 28px;
}

QToolButton:hover {
    background-color: #2e3340;
}

QToolButton:pressed {
    background-color: #2563eb;
    color: #ffffff;
}

QToolButton:checked {
    background-color: #2563eb;
    color: #ffffff;
}

QToolButton:disabled {
    color: #4b5563;
}

QToolButton::menu-button {
    border-left: 1px solid #2e3340;
    width: 16px;
}

/* ─── QLineEdit 单行输入框 ─── */
QLineEdit {
    background-color: #22262e;
    color: #e2e8f0;
    border: 1px solid #2e3340;
    border-radius: 4px;
    padding: 4px 8px;
    min-height: 26px;
    selection-background-color: #2563eb;
    selection-color: #ffffff;
}

QLineEdit:focus {
    border-color: #2563eb;
    background-color: #1e2230;
}

QLineEdit:disabled {
    background-color: #1a1d23;
    color: #4b5563;
    border-color: #2e3340;
}

QLineEdit:read-only {
    background-color: #1e2230;
    color: #94a3b8;
}

/* ─── QTextEdit 多行文本框 ─── */
QTextEdit {
    background-color: #22262e;
    color: #e2e8f0;
    border: 1px solid #2e3340;
    border-radius: 4px;
    padding: 4px;
    selection-background-color: #2563eb;
    selection-color: #ffffff;
}

QTextEdit:focus {
    border-color: #2563eb;
}

/* ─── QPlainTextEdit 纯文本框 ─── */
QPlainTextEdit {
    background-color: #22262e;
    color: #e2e8f0;
    border: 1px solid #2e3340;
    border-radius: 4px;
    padding: 4px;
    selection-background-color: #2563eb;
    selection-color: #ffffff;
}

QPlainTextEdit:focus {
    border-color: #2563eb;
}

/* ─── QComboBox 下拉选择框 ─── */
QComboBox {
    background-color: #22262e;
    color: #e2e8f0;
    border: 1px solid #2e3340;
    border-radius: 4px;
    padding: 4px 8px;
    min-height: 26px;
    min-width: 80px;
}

QComboBox:hover {
    border-color: #3b82f6;
}

QComboBox:focus {
    border-color: #2563eb;
}

QComboBox:disabled {
    background-color: #1a1d23;
    color: #4b5563;
}

/* 20260322 ZJH 下拉箭头区域 */
QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 24px;
    border-left: 1px solid #2e3340;
    border-top-right-radius: 4px;
    border-bottom-right-radius: 4px;
    background-color: #2e3340;
}

QComboBox::down-arrow {
    width: 0;
    height: 0;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 5px solid #94a3b8;
}

QComboBox::down-arrow:on {
    border-top: none;
    border-bottom: 5px solid #94a3b8;
}

/* 20260322 ZJH 下拉弹出列表视图 */
QComboBox QAbstractItemView {
    background-color: #22262e;
    color: #e2e8f0;
    border: 1px solid #2e3340;
    border-radius: 4px;
    selection-background-color: #2563eb;
    selection-color: #ffffff;
    outline: none;
    padding: 2px;
}

QComboBox QAbstractItemView::item {
    min-height: 26px;
    padding: 2px 8px;
    border-radius: 2px;
}

QComboBox QAbstractItemView::item:hover {
    background-color: #2e3340;
}

/* ─── QSpinBox 整数输入框 ─── */
QSpinBox {
    background-color: #22262e;
    color: #e2e8f0;
    border: 1px solid #2e3340;
    border-radius: 4px;
    padding: 4px 4px 4px 8px;
    min-height: 26px;
    selection-background-color: #2563eb;
}

QSpinBox:focus {
    border-color: #2563eb;
}

QSpinBox:disabled {
    background-color: #1a1d23;
    color: #4b5563;
}

QSpinBox::up-button,
QSpinBox::down-button {
    background-color: #2e3340;
    border: none;
    width: 20px;
}

QSpinBox::up-button:hover,
QSpinBox::down-button:hover {
    background-color: #3b82f6;
}

QSpinBox::up-arrow {
    width: 0;
    height: 0;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-bottom: 4px solid #94a3b8;
}

QSpinBox::down-arrow {
    width: 0;
    height: 0;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 4px solid #94a3b8;
}

/* ─── QDoubleSpinBox 浮点输入框（与 QSpinBox 保持一致） ─── */
QDoubleSpinBox {
    background-color: #22262e;
    color: #e2e8f0;
    border: 1px solid #2e3340;
    border-radius: 4px;
    padding: 4px 4px 4px 8px;
    min-height: 26px;
    selection-background-color: #2563eb;
}

QDoubleSpinBox:focus {
    border-color: #2563eb;
}

QDoubleSpinBox:disabled {
    background-color: #1a1d23;
    color: #4b5563;
}

QDoubleSpinBox::up-button,
QDoubleSpinBox::down-button {
    background-color: #2e3340;
    border: none;
    width: 20px;
}

QDoubleSpinBox::up-button:hover,
QDoubleSpinBox::down-button:hover {
    background-color: #3b82f6;
}

QDoubleSpinBox::up-arrow {
    width: 0;
    height: 0;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-bottom: 4px solid #94a3b8;
}

QDoubleSpinBox::down-arrow {
    width: 0;
    height: 0;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 4px solid #94a3b8;
}

/* ─── QSlider 水平/垂直滑条 ─── */
QSlider::groove:horizontal {
    background-color: #2e3340;
    height: 4px;
    border-radius: 2px;
}

/* 20260322 ZJH 已滑过部分用强调色高亮显示 */
QSlider::sub-page:horizontal {
    background-color: #2563eb;
    height: 4px;
    border-radius: 2px;
}

QSlider::handle:horizontal {
    background-color: #2563eb;
    border: 2px solid #3b82f6;
    width: 14px;
    height: 14px;
    border-radius: 7px;
    margin: -5px 0;
}

QSlider::handle:horizontal:hover {
    background-color: #3b82f6;
    border-color: #60a5fa;
}

QSlider::handle:horizontal:pressed {
    background-color: #1d4ed8;
}

QSlider::groove:vertical {
    background-color: #2e3340;
    width: 4px;
    border-radius: 2px;
}

QSlider::sub-page:vertical {
    background-color: #2563eb;
    width: 4px;
    border-radius: 2px;
}

QSlider::handle:vertical {
    background-color: #2563eb;
    border: 2px solid #3b82f6;
    width: 14px;
    height: 14px;
    border-radius: 7px;
    margin: 0 -5px;
}

/* ─── QProgressBar 进度条 ─── */
QProgressBar {
    background-color: #2e3340;
    border: none;
    border-radius: 4px;
    height: 8px;
    text-align: center;
    color: #e2e8f0;
    font-size: 11px;
}

QProgressBar::chunk {
    /* 20260322 ZJH 进度填充块使用强调蓝 */
    background-color: #2563eb;
    border-radius: 4px;
}

/* ─── QTabWidget 标签页容器 ─── */
QTabWidget::pane {
    background-color: #22262e;
    border: 1px solid #2e3340;
    border-radius: 0 4px 4px 4px;
    top: -1px;
}

QTabWidget::tab-bar {
    alignment: left;
}

/* ─── QTabBar 标签项（未选中/选中/悬停） ─── */
QTabBar::tab {
    background-color: #1a1d23;
    color: #94a3b8;
    border: 1px solid #2e3340;
    border-bottom: none;
    padding: 6px 16px;
    margin-right: 2px;
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
    min-width: 80px;
}

QTabBar::tab:selected {
    background-color: #22262e;
    color: #e2e8f0;
    border-color: #2e3340;
    border-bottom: 2px solid #2563eb;
}

QTabBar::tab:hover:!selected {
    background-color: #22262e;
    color: #e2e8f0;
}

QTabBar::tab:disabled {
    color: #4b5563;
}

/* ─── QMenuBar 顶部菜单栏 ─── */
QMenuBar {
    background-color: #1a1d23;
    color: #e2e8f0;
    border-bottom: 1px solid #2e3340;
    spacing: 2px;
    padding: 2px 4px;
}

QMenuBar::item {
    background-color: transparent;
    padding: 4px 10px;
    border-radius: 4px;
    color: #e2e8f0;
}

QMenuBar::item:selected {
    background-color: #2e3340;
    color: #ffffff;
}

QMenuBar::item:pressed {
    background-color: #2563eb;
    color: #ffffff;
}

/* ─── QMenu 下拉菜单 ─── */
QMenu {
    background-color: #22262e;
    color: #e2e8f0;
    border: 1px solid #2e3340;
    border-radius: 6px;
    padding: 4px 0;
}

QMenu::item {
    padding: 6px 28px 6px 12px;
    border-radius: 2px;
    min-width: 160px;
}

QMenu::item:selected {
    background-color: #2563eb;
    color: #ffffff;
}

QMenu::item:disabled {
    color: #4b5563;
}

QMenu::separator {
    height: 1px;
    background-color: #2e3340;
    margin: 4px 8px;
}

QMenu::indicator {
    width: 14px;
    height: 14px;
    margin-left: 6px;
}

/* ─── QListView / QListWidget 列表视图 ─── */
QListView,
QListWidget {
    background-color: #22262e;
    color: #e2e8f0;
    border: 1px solid #2e3340;
    border-radius: 4px;
    outline: none;
    alternate-background-color: #1e2230;
}

QListView::item,
QListWidget::item {
    padding: 4px 8px;
    min-height: 24px;
    border-radius: 2px;
}

QListView::item:selected,
QListWidget::item:selected {
    background-color: #2563eb;
    color: #ffffff;
}

QListView::item:hover,
QListWidget::item:hover {
    background-color: #2e3340;
}

/* ─── QTableWidget / QTableView 表格视图 ─── */
QTableWidget,
QTableView {
    background-color: #22262e;
    color: #e2e8f0;
    border: 1px solid #2e3340;
    border-radius: 4px;
    gridline-color: #2e3340;
    alternate-background-color: #1e2230;
    outline: none;
    selection-background-color: #2563eb;
    selection-color: #ffffff;
}

QTableWidget::item,
QTableView::item {
    padding: 4px 8px;
    border: none;
}

QTableWidget::item:selected,
QTableView::item:selected {
    background-color: #2563eb;
    color: #ffffff;
}

QTableWidget::item:hover,
QTableView::item:hover {
    background-color: #2e3340;
}

/* ─── QTreeView 树形视图 ─── */
QTreeView {
    background-color: #22262e;
    color: #e2e8f0;
    border: 1px solid #2e3340;
    border-radius: 4px;
    alternate-background-color: #1e2230;
    outline: none;
    selection-background-color: #2563eb;
}

QTreeView::item {
    padding: 3px 4px;
    min-height: 22px;
}

QTreeView::item:selected {
    background-color: #2563eb;
    color: #ffffff;
}

QTreeView::item:hover {
    background-color: #2e3340;
}

/* ─── QHeaderView 表头（表格、树形视图共用） ─── */
QHeaderView {
    background-color: #1a1d23;
    border: none;
}

QHeaderView::section {
    background-color: #1a1d23;
    color: #94a3b8;
    border: none;
    border-right: 1px solid #2e3340;
    border-bottom: 1px solid #2e3340;
    padding: 4px 8px;
    min-height: 28px;
    font-weight: 600;
    font-size: 12px;
}

QHeaderView::section:hover {
    background-color: #22262e;
    color: #e2e8f0;
}

QHeaderView::section:checked {
    background-color: #2563eb;
    color: #ffffff;
}

/* ─── QScrollBar 垂直滚动条（细条，悬停高亮） ─── */
QScrollBar:vertical {
    background-color: #1a1d23;
    width: 10px;
    border-radius: 5px;
    margin: 0;
}

QScrollBar::handle:vertical {
    background-color: #3a3f4b;
    border-radius: 5px;
    min-height: 30px;
}

QScrollBar::handle:vertical:hover {
    background-color: #4b5563;
}

QScrollBar::handle:vertical:pressed {
    background-color: #2563eb;
}

/* 20260322 ZJH 隐藏上下箭头按钮，保留纯轨道风格 */
QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0;
    border: none;
}

QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    background-color: transparent;
}

/* ─── QScrollBar 水平滚动条 ─── */
QScrollBar:horizontal {
    background-color: #1a1d23;
    height: 10px;
    border-radius: 5px;
    margin: 0;
}

QScrollBar::handle:horizontal {
    background-color: #3a3f4b;
    border-radius: 5px;
    min-width: 30px;
}

QScrollBar::handle:horizontal:hover {
    background-color: #4b5563;
}

QScrollBar::handle:horizontal:pressed {
    background-color: #2563eb;
}

QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal {
    width: 0;
    border: none;
}

QScrollBar::add-page:horizontal,
QScrollBar::sub-page:horizontal {
    background-color: transparent;
}

/* ─── QSplitter 分隔条 ─── */
QSplitter::handle {
    background-color: #2e3340;
}

QSplitter::handle:horizontal {
    width: 2px;
}

QSplitter::handle:vertical {
    height: 2px;
}

QSplitter::handle:hover {
    background-color: #2563eb;
}

/* ─── QGroupBox 分组框 ─── */
QGroupBox {
    background-color: transparent;
    color: #e2e8f0;
    border: 1px solid #2e3340;
    border-radius: 6px;
    margin-top: 16px;
    padding: 12px 8px 8px 8px;
    font-weight: 600;
    font-size: 12px;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 0 6px;
    left: 10px;
    color: #94a3b8;
    background-color: #1a1d23;
}

/* ─── QCheckBox 复选框 ─── */
QCheckBox {
    color: #e2e8f0;
    spacing: 8px;
    background-color: transparent;
}

QCheckBox:disabled {
    color: #4b5563;
}

QCheckBox::indicator {
    width: 16px;
    height: 16px;
    border: 1px solid #2e3340;
    border-radius: 3px;
    background-color: #22262e;
}

QCheckBox::indicator:hover {
    border-color: #3b82f6;
}

QCheckBox::indicator:checked {
    /* 20260322 ZJH 选中状态使用强调蓝填充 */
    background-color: #2563eb;
    border-color: #2563eb;
}

QCheckBox::indicator:checked:hover {
    background-color: #3b82f6;
    border-color: #3b82f6;
}

QCheckBox::indicator:disabled {
    background-color: #2e3340;
    border-color: #2e3340;
}

QCheckBox::indicator:indeterminate {
    background-color: #2563eb;
    border-color: #2563eb;
}

/* ─── QRadioButton 单选按钮 ─── */
QRadioButton {
    color: #e2e8f0;
    spacing: 8px;
    background-color: transparent;
}

QRadioButton:disabled {
    color: #4b5563;
}

QRadioButton::indicator {
    width: 16px;
    height: 16px;
    border: 1px solid #2e3340;
    border-radius: 8px;
    background-color: #22262e;
}

QRadioButton::indicator:hover {
    border-color: #3b82f6;
}

QRadioButton::indicator:checked {
    background-color: #2563eb;
    border-color: #2563eb;
}

QRadioButton::indicator:checked:hover {
    background-color: #3b82f6;
    border-color: #3b82f6;
}

QRadioButton::indicator:disabled {
    background-color: #2e3340;
    border-color: #2e3340;
}

/* ─── QStatusBar 状态栏 ─── */
QStatusBar {
    background-color: #1a1d23;
    color: #94a3b8;
    border-top: 1px solid #2e3340;
    font-size: 12px;
    padding: 2px 8px;
}

QStatusBar::item {
    border: none;
}

QStatusBar QLabel {
    color: #94a3b8;
    background-color: transparent;
    padding: 0 8px;
}

/* ─── QToolTip 悬浮提示 ─── */
QToolTip {
    background-color: #2e3340;
    color: #e2e8f0;
    border: 1px solid #3b82f6;
    border-radius: 4px;
    padding: 4px 8px;
    font-size: 12px;
    opacity: 230;
}

/* ─── QLabel 标签（保持透明背景，不干扰布局） ─── */
QLabel {
    color: #e2e8f0;
    background-color: transparent;
    padding: 0;
}

QLabel:disabled {
    color: #4b5563;
}

/* ─── QDockWidget 停靠窗口 ─── */
QDockWidget {
    background-color: #22262e;
    color: #e2e8f0;
}

QDockWidget::title {
    background-color: #1a1d23;
    color: #e2e8f0;
    padding: 6px 8px;
    border-bottom: 1px solid #2e3340;
    font-weight: 600;
    font-size: 12px;
    text-align: left;
}

QDockWidget::close-button,
QDockWidget::float-button {
    background-color: transparent;
    border: none;
    padding: 2px;
    border-radius: 3px;
}

QDockWidget::close-button:hover,
QDockWidget::float-button:hover {
    background-color: #2e3340;
}

/* ─── QToolBar 工具栏 ─── */
QToolBar {
    background-color: #1a1d23;
    border-bottom: 1px solid #2e3340;
    spacing: 4px;
    padding: 2px 4px;
}

QToolBar::separator {
    width: 1px;
    background-color: #2e3340;
    margin: 4px 4px;
}

/* ─── QFrame 水平/垂直分隔线 ─── */
QFrame[frameShape="4"] {
    color: #2e3340;
    background-color: #2e3340;
    max-height: 1px;
    border: none;
}

QFrame[frameShape="5"] {
    color: #2e3340;
    background-color: #2e3340;
    max-width: 1px;
    border: none;
}

/* ─── QDialog 对话框基础 ─── */
QDialog {
    background-color: #1a1d23;
    color: #e2e8f0;
}

QDialogButtonBox QPushButton {
    min-width: 80px;
}
